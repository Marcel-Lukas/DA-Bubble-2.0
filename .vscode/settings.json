{
  // Fehler/Warnungen aus node_modules ausblenden (z. B. veraltete tsconfig-Optionen in rxjs)
  "typescript.tsserver.experimental.enableProjectDiagnostics": false,

  // node_modules nicht überwachen (bessere Performance, keine Fremd-Fehler)
  "files.watcherExclude": {
    "**/node_modules/**": true
  },

  // node_modules im Such- und Datei-Explorer ausblenden bzw. von der Suche ausnehmen
  "search.exclude": {
    "**/node_modules": true
  }
}
